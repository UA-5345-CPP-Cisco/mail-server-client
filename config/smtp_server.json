{
	"database": {
		"storage_path": "data/mail-server-example.db",
		"migrations_path": "libs/mail_storage/migrations"
	},
	"server": {
		"host": "0.0.0.0",
		"port": 2525,
		"server_name": "localhost",
		"max_connections": 1024,
		"max_message_size_bytes": 10485760,
		"require_authentication": false,
		"allow_plain_authentication_without_tls": false
	},
	"delivery": {
		"batch_size": 32,
		"poll_interval_ms": 100
	},
	"tls": {
		"enabled": false,
		"certificate_path": "",
		"private_key_path": ""
	}
}
